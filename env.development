# === Environment ===
HUMANDBS_ENV=development
HUMANDBS_NODE_ENV=development
HUMANDBS_TZ=Asia/Tokyo

# === Nginx ===
HUMANDBS_NGINX_BIND_HOST=127.0.0.1
HUMANDBS_NGINX_PORT=8080

# === Elasticsearch ===
HUMANDBS_ES_MEM_LIMIT=4g
HUMANDBS_ES_JAVA_OPTS="-Xms2g -Xmx2g"
HUMANDBS_ES_BACKUP_PATH=./humandbs-es-backup

# === Files (legacy static files served by nginx) ===
HUMANDBS_FILES_DIR=./humandbs-files-dev

# === Database ===
HUMANDBS_POSTGRES_USER=humandbs
HUMANDBS_POSTGRES_PASSWORD=mysecretpassword
HUMANDBS_POSTGRES_DB=humandbs

# === Auth (External Access) ===
HUMANDBS_AUTH_ISSUER_URL=https://idp-staging.ddbj.nig.ac.jp/realms/master
HUMANDBS_AUTH_CLIENT_ID=humandbs-dev
HUMANDBS_AUTH_REDIRECT_URI=http://localhost:8080/auth/callback

# === JGA-shinsei DB ===
# 接続先・credentials は .claude/docs/jga-shinsei-db-access.md を参照して埋める
# REQUIRED: HUMANDBS_JGA_DB_HOST / _USER / _PASSWORD (compose.yml で必須化)
HUMANDBS_JGA_DB_HOST=
HUMANDBS_JGA_DB_PORT=5432
HUMANDBS_JGA_DB_USER=
HUMANDBS_JGA_DB_PASSWORD=
HUMANDBS_JGA_DB_NAME=jgadb
HUMANDBS_JGA_DB_SCHEMA=jgasys

# === Admin Configuration ===
HUMANDBS_BACKEND_ADMIN_UID_FILE=/app/admin_uids.json

# === Frontend ===
HUMANDBS_FRONTEND_PUBLIC_FILES_DIR=public-files
HUMANBDS_FRONTEND_DU_APPLICATION_URL=https://ts-humandbs.ddbj.nig.ac.jp/nbdc/application/import_form
HUMANDBS_BACKEND_ORIGIN=https://humandbs-staging.ddbj.nig.ac.jp
HUMANDBS_BACKEND_BASE_URL=${HUMANDBS_BACKEND_ORIGIN}/api

# === Commands ===
HUMANDBS_FRONTEND_COMMAND="sleep infinity"
HUMANDBS_BACKEND_COMMAND="sleep infinity"
