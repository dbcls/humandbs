{
  "name": "@humandbs/frontend",
  "version": "0.1",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "vite dev --host 0.0.0.0 --port 3000",
    "build": "NODE_ENV=production vite build",
    "preview": "vite preview",
    "start": "NODE_ENV=production bun server.ts",
    "db:reset": "bun ./src/scripts/database/reset-db.ts",
    "db:clear": "bun ./src/scripts/database/clear-db.ts",
    "db:seed-documents": "bun ./src/scripts/database/seed-documents.ts",
    "db:seed-files": "bun ./src/scripts/database/seed-files.ts",
    "db:seed-navigation": "bun ./src/scripts/database/seed-navigation.ts",
    "db:seed-news": "bun ./src/scripts/database/seed-news.ts",
    "db:seed-content": "bun ./src/scripts/database/seed-content.ts",
    "db:seed-navigation-flowcharts": "bun ./src/scripts/database/seed-navigation-flowcharts.ts",
    "db:seed-all": "bun run db:seed-documents && bun run db:seed-files && bun run db:seed-navigation && bun run db:seed-news && bun run db:seed-content && bun run db:seed-navigation-flowcharts",
    "db:generate": "bunx --bun drizzle-kit generate",
    "db:migrate": "bunx --bun drizzle-kit migrate",
    "db:push": "bunx --bun drizzle-kit push",
    "format": "bunx prettier --write 'src/**/*.{js,ts,jsx,tsx}'"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/helpers": "^0.3.2",
