    "cheerio": "^1.2.0",
    "drizzle-kit": "^0.31.9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.3",
    "shadcn": "^3.8.4",
    "tailwindcss": "^4.1.18",
    "turndown": "^7.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.2",
    "vite": "^7.3.1",
    "vite-plugin-svgr": "^4.5.0",
