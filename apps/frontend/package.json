    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "remark-toc": "^9.0.0",
    "shiki": "^3.22.0",
    "tailwind-merge": "^3.4.0",
    "tar-stream": "^3.2.0",
    "unified": "^11.0.5",
    "use-intl": "^4.8.2",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@humandbs/eslint-config": "workspace:*",
    "@rsbuild/core": "^2.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/eslint-plugin-query": "^5.100.10",
