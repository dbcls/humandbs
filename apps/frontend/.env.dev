# === Container Settings ===
HUMANDBS_CONTAINER_PREFIX=humandbs-dev
HUMANDBS_NETWORK_NAME=humandbs-network
HUMANDBS_NODE_ENV=development
HUMANDBS_TZ=Asia/Tokyo

# === Nginx ===
HUMANDBS_NGINX_BIND_HOST=127.0.0.1
HUMANDBS_NGINX_PORT=8080

# === Elasticsearch ===
HUMANDBS_ES_MEM_LIMIT=4g
HUMANDBS_ES_JAVA_OPTS=-Xms2g -Xmx2g
HUMANDBS_ES_BACKUP_PATH=./humandbs-es-backup

# === Database ===
HUMANDBS_POSTGRES_USER=humandbs
HUMANDBS_POSTGRES_PASSWORD=mysecretpassword
HUMANDBS_POSTGRES_DB=humandbs
HUMANDBS_POSTGRES_HOST=localhost
HUMANDBS_POSTGRES_PORT=5432

# === Auth (External Access) ===

# === Admin Configuration ===
HUMANDBS_BACKEND_ADMIN_UID_FILE=/app/admin_uids.json

# === Commands ===
HUMANDBS_FRONTEND_COMMAND=sleep infinity
HUMANDBS_BACKEND_COMMAND=sleep infinity

# === Dev ===
# AUTH_DEV_BYPASS=true
# AUTH_DEV_ROLE=admin
# Optional: override mock user fields (must match a UID in admin_uids.json for admin access)
# AUTH_DEV_USER_ID=actual-admin-user-id-1
# AUTH_DEV_NAME=My Name
# AUTH_DEV_EMAIL=me@example.com
# AUTH_DEV_USERNAME=myusername
