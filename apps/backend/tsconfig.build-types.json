{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "outDir": "./dist/types",
    "rootDir": ".",
    "noEmit": false,
    "allowImportingTsExtensions": false,
  },
  "include": [
    "types/shared-types.ts",
    "src/api/types/**/*.ts",
    "src/es/types.ts",
    "src/crawler/types/**/*.ts",
  ],
}
