# JGA Shinsei 環境設定 (バッチスクリプト用)
# cp env.template .env して編集する
#
# NOTE: API サーバーは別の env を使用する。root の .env / compose.yml で
# HUMANDBS_JGA_DB_* (HOST/PORT/USER/PASSWORD/NAME/SCHEMA) を設定すること。
# このファイルはあくまで scripts/ 配下の dump スクリプト用。

# --- dump-all-data.sh (direct psql) ---
JGA_DB_HOST=
JGA_DB_PORT=5432
JGA_DB_USER=postgres
JGA_DB_PASSWORD=
JGA_DB_NAME=jgadb
JGA_DB_SCHEMA=jgasys

# --- dump-all-data-docker.sh ---
# JGA_CONTAINER_NAME=humandbs-jga-shinsei-db

# --- 共通 ---
# JSON 出力ディレクトリ (jga-shinsei からの相対パス or 絶対パス)
JGA_OUTPUT_DIR=./json-data

# --- dump-jga-hum-relations.sh ---
# TSV 出力ディレクトリ (絶対パス、デフォルト: ~/jga-relation)
# JGA_HUM_REL_OUTPUT_DIR=/home/w3humandbs-ac/jga-relation
